@startuml
!include <C4/C4_Context>
!include <C4/C4_Container>

' ===== Diagrama 1 =====
title Diagrama de Contexto - TaskFlow

Person(usuario, "Usuário", "Pessoa que gerencia suas tarefas")

System(taskflow, "TaskFlow", "Aplicação de lista de tarefas (To-Do List)")

Rel(usuario, taskflow, "Usa", "HTTPS")

' ===== Diagrama 2 =====
title Diagrama de Container - TaskFlow

System_Boundary(taskflow_boundary, "TaskFlow") {
    Container(frontend, "Frontend", "Next.js, TypeScript, Tailwind, shadcn/ui", "Interface web responsiva que consome a API REST")
    Container(backend, "Backend", "Spring Boot, Java 21, Maven", "API RESTful que gerencia as tarefas")
    ContainerDb(db, "Banco de Dados", "PostgreSQL", "Armazena as tarefas")
}

Rel(frontend, backend, "Chama API", "HTTP/REST, JSON")
Rel(backend, db, "Leitura/Escrita", "JDBC")

Rel(usuario, frontend, "Acessa", "HTTPS")

@enduml